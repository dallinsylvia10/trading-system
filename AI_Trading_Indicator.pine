// ============================================================
// AI SMART SIGNAL — Buy/Sell + SL/TP Indicator
// Compatible with: TradingView Pine Script v5
// Strategy: Multi-confluence (EMA trend + RSI + MACD + ATR SL/TP)
// ============================================================

//@version=5
indicator("AI Smart Signal [Buy/Sell + SL/TP]", overlay=true, max_labels_count=500)

// ─────────────────────────────────────────
// ░░  USER INPUTS
// ─────────────────────────────────────────
grp1 = "📊 Trend Filter (EMA)"
emaFastLen  = input.int(21,  "Fast EMA",  minval=1,  group=grp1)
emaSlowLen  = input.int(50,  "Slow EMA",  minval=1,  group=grp1)
emaTrendLen = input.int(200, "Trend EMA", minval=1,  group=grp1)

grp2 = "📈 Momentum (RSI)"
rsiLen      = input.int(14,   "RSI Length",    minval=2,  group=grp2)
rsiOB       = input.int(65,   "RSI Overbought",minval=50, group=grp2)
rsiOS       = input.int(35,   "RSI Oversold",  maxval=50, group=grp2)

grp3 = "⚡ MACD"
macdFast    = input.int(12, "MACD Fast", group=grp3)
macdSlow    = input.int(26, "MACD Slow", group=grp3)
macdSig     = input.int(9,  "MACD Signal", group=grp3)

grp4 = "🎯 Risk Management (ATR)"
atrLen      = input.int(14,  "ATR Length",       minval=1,   group=grp4)
slMult      = input.float(1.5,"SL ATR Multiplier",step=0.1,  group=grp4)
tpMult      = input.float(2.5,"TP ATR Multiplier",step=0.1,  group=grp4)

grp5 = "🎨 Visual"
showEMAs    = input.bool(true, "Show EMAs", group=grp5)
showLabels  = input.bool(true, "Show SL/TP Labels", group=grp5)

// ─────────────────────────────────────────
// ░░  CALCULATIONS
// ─────────────────────────────────────────

// EMAs
emaFast  = ta.ema(close, emaFastLen)
emaSlow  = ta.ema(close, emaSlowLen)
emaTrend = ta.ema(close, emaTrendLen)

// RSI
rsi = ta.rsi(close, rsiLen)

// MACD
[macdLine, signalLine, hist] = ta.macd(close, macdFast, macdSlow, macdSig)

// ATR for dynamic SL/TP
atr = ta.atr(atrLen)

// ─────────────────────────────────────────
// ░░  SIGNAL CONDITIONS (Multi-Confluence)
// ─────────────────────────────────────────

// Trend: price above/below 200 EMA
bullTrend = close > emaTrend
bearTrend = close < emaTrend

// EMA crossover
emaBullCross = ta.crossover(emaFast, emaSlow)
emaBearCross = ta.crossunder(emaFast, emaSlow)

// MACD crossover
macdBull = ta.crossover(macdLine, signalLine)
macdBear = ta.crossunder(macdLine, signalLine)

// RSI confirmation (not overbought on buy, not oversold on sell)
rsiBuyOK  = rsi > 40 and rsi < rsiOB
rsiSellOK = rsi < 60 and rsi > rsiOS

// ─── FINAL SIGNALS ───
buySignal  = emaBullCross and macdBull  and rsiBuyOK  and bullTrend
sellSignal = emaBearCross and macdBear  and rsiSellOK and bearTrend

// ─────────────────────────────────────────
// ░░  SL / TP LEVELS
// ─────────────────────────────────────────

// BUY levels
buySL = close - (atr * slMult)
buyTP = close + (atr * tpMult)

// SELL levels
sellSL = close + (atr * slMult)
sellTP = close - (atr * tpMult)

// ─────────────────────────────────────────
// ░░  VISUALS — EMAs
// ─────────────────────────────────────────

plot(showEMAs ? emaFast  : na, "EMA Fast",  color=color.new(color.aqua,   20), linewidth=1)
plot(showEMAs ? emaSlow  : na, "EMA Slow",  color=color.new(color.orange, 20), linewidth=1)
plot(showEMAs ? emaTrend : na, "EMA Trend", color=color.new(color.white,  40), linewidth=2, style=plot.style_circles)

// ─────────────────────────────────────────
// ░░  VISUALS — BUY / SELL ARROWS
// ─────────────────────────────────────────

plotshape(buySignal,  title="BUY",  location=location.belowbar, style=shape.labelup,
          color=color.new(color.lime, 0), textcolor=color.black, text="BUY", size=size.normal)

plotshape(sellSignal, title="SELL", location=location.abovebar, style=shape.labeldown,
          color=color.new(color.red,  0), textcolor=color.white, text="SELL", size=size.normal)

// ─────────────────────────────────────────
// ░░  VISUALS — SL / TP LABELS
// ─────────────────────────────────────────

if buySignal and showLabels
    label.new(bar_index, buySL,
              text="🛑 SL: " + str.tostring(math.round(buySL, 2)),
              color=color.new(color.red, 20), textcolor=color.white,
              style=label.style_label_up, size=size.small)
    label.new(bar_index, buyTP,
              text="🎯 TP: " + str.tostring(math.round(buyTP, 2)),
              color=color.new(color.green, 20), textcolor=color.white,
              style=label.style_label_down, size=size.small)

if sellSignal and showLabels
    label.new(bar_index, sellSL,
              text="🛑 SL: " + str.tostring(math.round(sellSL, 2)),
              color=color.new(color.red, 20), textcolor=color.white,
              style=label.style_label_down, size=size.small)
    label.new(bar_index, sellTP,
              text="🎯 TP: " + str.tostring(math.round(sellTP, 2)),
              color=color.new(color.green, 20), textcolor=color.white,
              style=label.style_label_up, size=size.small)

// ─────────────────────────────────────────
// ░░  BACKGROUND TREND HIGHLIGHT
// ─────────────────────────────────────────

bgcolor(bullTrend ? color.new(color.green, 95) : color.new(color.red, 95), title="Trend BG")

// ─────────────────────────────────────────
// ░░  INFO TABLE (top-right corner)
// ─────────────────────────────────────────

var table infoTable = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.black, 60), border_color=color.gray, border_width=1, frame_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "INDICATOR",   text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 0, "AI SIGNAL",   text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 1, "TREND",       text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 1, bullTrend ? "▲ BULL" : "▼ BEAR",
               text_color=bullTrend ? color.lime : color.red, text_size=size.small)

    table.cell(infoTable, 0, 2, "RSI",         text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(math.round(rsi, 1)),
               text_color=rsi > rsiOB ? color.red : rsi < rsiOS ? color.lime : color.white,
               text_size=size.small)

    table.cell(infoTable, 0, 3, "MACD",        text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 3, hist >= 0 ? "▲ BULL" : "▼ BEAR",
               text_color=hist >= 0 ? color.lime : color.red, text_size=size.small)

    table.cell(infoTable, 0, 4, "ATR",         text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 4, str.tostring(math.round(atr, 4)), text_color=color.yellow, text_size=size.small)

    table.cell(infoTable, 0, 5, "SIGNAL",      text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 5,
               buySignal ? "⬆ BUY" : sellSignal ? "⬇ SELL" : "◼ WAIT",
               text_color=buySignal ? color.lime : sellSignal ? color.red : color.gray,
               text_size=size.small)

// ─────────────────────────────────────────
// ░░  ALERTS
// ─────────────────────────────────────────

alertcondition(buySignal,  title="AI BUY Signal",  message="🟢 BUY Signal detected! Check SL/TP on chart.")
alertcondition(sellSignal, title="AI SELL Signal", message="🔴 SELL Signal detected! Check SL/TP on chart.")
